{
  "extends": "@thomasar-cv/tsconfig/base.json",
  "compilerOptions": {
    // The recorder runs code inside the browser via page.evaluate(), which
    // references `document` / `HTMLElement`, so DOM types are needed even though
    // this is a Node-run tool.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    // Node globals (process, node:* modules) aren't auto-included: unlike
    // packages/db, nothing in this package's dep graph transitively pulls in
    // @types/node, so it must be declared explicitly.
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
