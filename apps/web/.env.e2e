# Local e2e environment, loaded by scripts/e2e.mjs and playwright.config.ts.
# These point the app and the seed connection at the throwaway Postgres that
# docker-compose.e2e.yml brings up, so a local e2e run never touches the shared
# Supabase project. The secret is deliberately not a real secret: it only signs
# cookies for the ephemeral run. CI sets its own DATABASE_URL / BETTER_AUTH_SECRET
# at the job level, and both loaders leave already-set vars alone, so this file
# is ignored there.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres
BETTER_AUTH_SECRET=local-e2e-secret-not-used-outside-this-run-0123456789
