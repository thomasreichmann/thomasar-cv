# Supabase Postgres connection for the shared "nexus" project (resume schema).
#
# Use the TRANSACTION POOLER url (host ...pooler.supabase.com, port 6543), not the
# direct connection. `createDb()` sets `prepare: false` because the transaction
# pooler runs in transaction mode and rejects prepared statements.
#
# Supabase dashboard -> Project Settings -> Database -> Connection string -> Transaction pooler.
# Copy this file to .env.local and fill in the value (same creds as packages/db/.env).
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@AWS_REGION.pooler.supabase.com:6543/postgres"
