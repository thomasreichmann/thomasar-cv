# This file documents what the web app's server env needs. The values already
# live on Vercel, so the easy path is to fetch them: after `vercel login` and
# `vercel link`, run `pnpm env:pull` (from the repo root) to write .env.local.
# Only copy this file to .env.local by hand if you have no Vercel access.
#
# Supabase Postgres connection for the shared "nexus" project (resume schema).
#
# Use the TRANSACTION POOLER url (host ...pooler.supabase.com, port 6543), not the
# direct connection. `createDb()` sets `prepare: false` because the transaction
# pooler runs in transaction mode and rejects prepared statements.
#
# Supabase dashboard -> Project Settings -> Database -> Connection string -> Transaction pooler.
# Copy this file to .env.local and fill in the value (same creds as packages/db/.env).
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@AWS_REGION.pooler.supabase.com:6543/postgres"

# BetterAuth secret used to sign session cookies. Generate one with
# `openssl rand -base64 32` (must be at least 32 characters). Keep it secret;
# set the same kind of value on Vercel for both Production and Preview.
BETTER_AUTH_SECRET="generate-a-32+-char-random-string"

# Optional: pin the canonical origin BetterAuth uses. Leave unset to derive it
# from the incoming request (works for Vercel preview URLs, which vary). Set it
# only for a stable production domain, e.g. https://your-domain.com
# BETTER_AUTH_URL=""
