{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  // Turbo 2.x runs tasks in strict env mode: vars not listed here are stripped
  // from task processes, so the eager db singleton's DATABASE_URL (and future
  // secrets) would be missing under `turbo run build`/`test` even when set.
  // Pass everything through, mirroring nexus.
  "globalPassThroughEnv": ["*"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {},
    // `typecheck` and `test` consume workspace dependencies as TS source (web
    // imports @thomasar-cv/db etc.), so they must hash those deps' inputs - else a
    // change in packages/db (a schema column, a migration .sql) leaves a
    // dependent's cached result valid and `pnpm check` passes while CI, on a cold
    // cache, fails. The `^typecheck`/`^test` edges pull each dependency's source
    // into the dependent's hash, keeping `pnpm check` a true mirror of CI.
    "typecheck": { "dependsOn": ["^typecheck"] },
    "test": { "dependsOn": ["^test"] }
  }
}
