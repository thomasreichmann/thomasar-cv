# Dependencies
node_modules/
.pnp
.pnp.*

# Build output
.next/
out/
dist/
build/
.turbo/

# Testing
coverage/
playwright-report/
test-results/
blob-report/
.playwright/

# Capture toolkit scratch (raw video, palettes, saved auth state)
tooling/capture/.tmp/
# Saved Playwright auth state (contains live session cookies). No trailing
# slash, so a symlink of this name (local worktree setup) is ignored too.
**/e2e/.auth

# Environment
.env
.env.*
!.env.example
# Throwaway local e2e config (ephemeral database, no real secrets); see apps/web/e2e.
!.env.e2e

# Vercel (no trailing slash: also ignores a symlink of this name)
.vercel

# Reference CV (private for now; remove this line to publish)
/reference/*.pdf

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# TypeScript
*.tsbuildinfo
next-env.d.ts
